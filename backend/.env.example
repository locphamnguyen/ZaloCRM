PORT=3000
NODE_ENV=production
APP_URL=https://your-domain.com

JWT_SECRET=          # openssl rand -hex 32
ENCRYPTION_KEY=      # openssl rand -hex 16

DB_USER=crmuser
DB_PASSWORD=         # your password
DB_NAME=zalocrm
DATABASE_URL=postgresql://crmuser:password@db:5432/zalocrm

UPLOAD_DIR=/var/lib/zalo-crm/files

# ── Facebook Lead Ingestion ──────────────────────────────────────────────────
FB_APP_ID=                     # Meta App ID
FB_APP_SECRET=                 # Meta App Secret (keep secret!)
FB_WEBHOOK_VERIFY_TOKEN=       # Random string you set in Meta App Dashboard → Webhooks
FB_TOKEN_ENC_KEY=              # 64-char hex (32 bytes): openssl rand -hex 32
FB_OAUTH_REDIRECT_URI=         # e.g. https://your-domain.com/api/v1/integrations/facebook/oauth/callback
FB_GRAPH_API_VERSION=v23.0    # Graph API version

AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
